      "State 2: ('living_beings', 4)\n",
      "State 3: ('travel', 1)\n",
      "State 4: ('clothing', 2)\n",
      "State 5: ('hospitality', 3)\n",
      "State 6: ('clothing', 0)\n",
      "State 7: ('travel', 2)\n",
      "State 8: ('travel', 5)\n",
      "State 9: ('basics', 1)\n",
      "\n",
      "Recommended Quiz:\n",
      "    newari_word nepali_meaning  category  expertise_lvl        type\n",
      "621      तुपुली           टोपी  clothing              0  vocabulary\n"
     ]
